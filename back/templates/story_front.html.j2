<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 0; padding: 0; background: #121212; color: #eee; }
    .app { max-width: 1000px; margin: auto; padding: 16px; }
    .header { text-align: center; margin-bottom: 16px; }
    .scene { display: grid; grid-template-columns: 340px 1fr; gap: 16px; }
    .card { background: #1e1e1e; border-radius: 14px; padding: 18px; box-shadow: 0 14px 34px rgba(0,0,0,0.25); }
    .scene-image { border-radius: 12px; overflow: hidden; }
    .scene-image img { width: 100%; display: block; }
    .scene-content h2 { margin: 0 0 10px; }
    .scene-content p { line-height: 1.6; color: #ccc; }
    .options { list-style: none; padding: 0; margin: 0; display: grid; gap: 10px; }
    .options button { width: 100%; background: #2b2b2b; color: #fff; border: 1px solid #333; border-radius: 10px; padding: 14px 16px; cursor: pointer; text-align: left; transition: transform .12s ease, background .12s ease; }
    .options button:hover { transform: translateY(-1px); background: #313131; }
    .options button:disabled { opacity: .5; cursor: not-allowed; }
    .player-panel { display: grid; gap: 14px; margin-top: 16px; }
    .stats, .inventory, .fight { display: grid; gap: 10px; }
    .stats-item, .inventory-item { display: flex; justify-content: space-between; padding: 10px 12px; background: #0f0f0f; border-radius: 10px; }
    .section-title { margin: 0 0 8px; font-size: 1rem; text-transform: uppercase; letter-spacing: .08em; color: #9e9e9e; }
    .status { margin-top: 14px; padding: 12px 14px; background: #151515; border-radius: 12px; min-height: 44px; }
    .fight-options { display: grid; gap: 10px; }
  </style>
</head>
<body>
  <div class="app">
    <div class="header">
      <h1>{{ title }}</h1>
      <p>{{ description }}</p>
    </div>

    <div class="scene">
      <div class="card scene-image">
        <img id="sceneImage" alt="Scene image" src="" />
      </div>
      <div class="card scene-content">
        <h2 id="sceneHeader"></h2>
        <p id="sceneBody"></p>
        <div id="optionsArea">
          <p class="section-title">Choices</p>
          <div id="options" class="options"></div>
        </div>
        <div id="fightArea" class="fight" style="display:none;">
          <p class="section-title">Fight</p>
          <div id="fightDescription"></div>
          <div id="fightOptions" class="fight-options"></div>
        </div>
        <div class="status" id="statusBar"></div>
      </div>
    </div>

    <div class="player-panel">
      <div class="card stats">
        <p class="section-title">Player Stats</p>
        <div id="statsList"></div>
      </div>
      <div class="card inventory">
        <p class="section-title">Inventory</p>
        <div id="inventoryList"></div>
      </div>
    </div>
  </div>

  <script>
    const imageBase = '{{ asset_base }}';
    const storyData = {{ story_json | safe }};

    const state = {
      currentRoom: storyData.rooms[0].name,
      variables: { ...storyData.variables },
      inventory: [],
      fightMode: false,
      bossHpVar: storyData.bossStrengthVar,
      playerStrVar: storyData.playerStrengthVar,
      statusText: 'Dobrodošli u avanturu!'
    };

    function getRoom(roomName) {
      return storyData.rooms.find(r => r.name === roomName);
    }

    function evaluateExpression(exp) {
      if (!exp) return 0;
      switch (exp.type) {
        case 'value': return exp.value;
        case 'var': return state.variables[exp.name] || 0;
        case 'random': return randInt(exp.from, exp.to);
        case 'binary': {
          let result = evaluateExpression(exp.left);
          for (let i = 0; i < exp.ops.length; i++) {
            const op = exp.ops[i];
            const right = evaluateExpression(exp.rights[i]);
            if (op === '+') result += right;
            if (op === '-') result -= right;
            if (op === '*') result *= right;
            if (op === '/') result = right !== 0 ? Math.floor(result / right) : 0;
          }
          return result;
        }
        default: return 0;
      }
    }

    function randInt(min, max) {
      return Math.floor(Math.random() * (max - min + 1)) + min;
    }

    function conditionSatisfied(condition) {
      if (!condition) return true;
      const left = evaluateExpression(condition.left);
      const right = evaluateExpression(condition.right);
      switch (condition.op) {
        case '==': return left == right;
        case '>=': return left >= right;
        case '<=': return left <= right;
        case '>': return left > right;
        case '<': return left < right;
        default: return false;
      }
    }

    function applyAssignments(assignments) {
      if (!assignments) return;
      for (const assignment of assignments) {
        state.variables[assignment.varName] = evaluateExpression(assignment.exp);
      }
    }

    function applyRules(rules) {
      if (!rules) return;
      for (const rule of rules) {
        applyAssignments(rule.assignments);
      }
    }

    function applyAction(action) {
      if (!action) return;
      if (action.type === 'restart') {
        restartAdventure();
        return;
      }
      if (action.type === 'buy') {
        const weapon = storyData.weapons.find(w => w.name === action.item);
        if (!weapon) {
          state.statusText = `Ne postoji oružje ${action.item}.`;
          return;
        }
        if ((state.variables.gold || 0) < weapon.value) {
          state.statusText = 'Nemaš dovoljno zlata za ovu kupovinu.';
          return;
        }
        state.variables.gold -= weapon.value;
        state.inventory.push({ name: weapon.name, hp: weapon.hp });
        state.statusText = `Kupljen je ${weapon.name}.`; 
      }
      if (action.type === 'take') {
        if (action.item) {
          const treasure = storyData.treasures.find(t => t.name === action.item);
          if (treasure) {
            state.inventory.push({ name: treasure.name, hp: treasure.weight });
            const playerStrength = state.playerStrVar;
            if (playerStrength && state.variables[playerStrength] != null) {
              state.variables[playerStrength] = Math.max(0, state.variables[playerStrength] - treasure.weight);
            }
          }
        }
        applyAssignments(action.assignments);
        applyRules(action.rules);
      }
      if (action.randoms) {
        for (const randomAssign of action.randoms) {
          state.variables[randomAssign.name] = randInt(randomAssign.from, randomAssign.to);
        }
      }
    }

    function restartAdventure() {
      state.currentRoom = storyData.rooms[0].name;
      state.variables = { ...storyData.variables };
      state.inventory = [];
      state.fightMode = false;
      state.statusText = 'Avantura je resetovana.';
    }

    function roomOptions(room) {
      if (room.fight) {
        return [];
      }
      return room.options.filter(opt => conditionSatisfied(opt.condition));
    }

    function buildFightOptions(fight) {
      const hrRange = storyData.hitRanges[fight.hr] || { from: 1, to: 1 };
      const options = [
        { text: `Udari (${hrRange.from}-${hrRange.to} dmg)`, type: 'punch' }
      ];
      for (const item of state.inventory) {
        options.push({ text: `Koristi ${item.name} (+${item.hp} dmg)`, type: 'weapon', weapon: item });
      }
      return options;
    }

    function fightTurn(choice) {
      const room = getRoom(state.currentRoom);
      if (!room?.fight) return;
      const fight = room.fight;
      const playerStrengthKey = state.playerStrVar;
      const bossStrengthKey = state.bossHpVar;
      if (!playerStrengthKey || !bossStrengthKey) return;
      let damageToBoss = 0;
      if (choice.type === 'punch') {
        const hr = storyData.hitRanges[fight.hr] || { from: 1, to: 1 };
        damageToBoss = randInt(hr.from, hr.to);
      } else if (choice.type === 'weapon') {
        damageToBoss = choice.weapon.hp;
        state.inventory = state.inventory.filter(inv => inv !== choice.weapon);
      }
      state.variables[bossStrengthKey] = Math.max(0, (state.variables[bossStrengthKey] || 0) - damageToBoss);
      const bossHitRange = Object.entries(storyData.hitRanges).find(([name]) => name !== fight.hr)?.[1] || { from: 1, to: 1 };
      const damageToPlayer = randInt(bossHitRange.from, bossHitRange.to);
      state.variables[playerStrengthKey] = Math.max(0, (state.variables[playerStrengthKey] || 0) - damageToPlayer);
      state.statusText = `Tvoj udar: ${damageToBoss}, boss udar: ${damageToPlayer}.`;
      if (state.variables[bossStrengthKey] <= 0) {
        state.currentRoom = fight.winRoom;
        state.fightMode = false;
        state.statusText += ' Boss je poražen!';
      } else if (state.variables[playerStrengthKey] <= 0) {
        state.currentRoom = fight.loseRoom;
        state.fightMode = false;
        state.statusText += ' Izgubio si borbu.';
      }
      render();
    }

    function goToRoom(targetName) {
      state.currentRoom = targetName;
      state.fightMode = false;
      render();
    }

    function render() {
      const room = getRoom(state.currentRoom);
      if (!room) return;
      document.getElementById('sceneImage').src = room.imagePath ? imageBase + room.imagePath : '';
      document.getElementById('sceneHeader').textContent = room.header;
      document.getElementById('sceneBody').textContent = room.body;
      document.getElementById('statusBar').textContent = state.statusText;

      const statsList = document.getElementById('statsList');
      statsList.innerHTML = '';
      for (const [name, value] of Object.entries(state.variables)) {
        const stat = document.createElement('div');
        stat.className = 'stats-item';
        stat.innerHTML = `<strong>${name}</strong><span>${value}</span>`;
        statsList.appendChild(stat);
      }

      const inventoryList = document.getElementById('inventoryList');
      inventoryList.innerHTML = '';
      if (state.inventory.length === 0) {
        inventoryList.innerHTML = '<div class="inventory-item">Prazan inventar</div>';
      } else {
        state.inventory.forEach(item => {
          const inv = document.createElement('div');
          inv.className = 'inventory-item';
          inv.innerHTML = `<span>${item.name}</span><span>HP ${item.hp}</span>`;
          inventoryList.appendChild(inv);
        });
      }

      const optionsArea = document.getElementById('optionsArea');
      const fightArea = document.getElementById('fightArea');
      const optionsContainer = document.getElementById('options');
      optionsContainer.innerHTML = '';

      if (room.fight) {
        state.fightMode = true;
      }

      if (state.fightMode && room.fight) {
        fightArea.style.display = 'block';
        optionsArea.style.display = 'none';
        document.getElementById('fightDescription').textContent = room.fight.description;
        const fightOptions = document.getElementById('fightOptions');
        fightOptions.innerHTML = '';
        buildFightOptions(room.fight).forEach((opt, index) => {
          const btn = document.createElement('button');
          btn.textContent = opt.text;
          btn.onclick = () => fightTurn(opt);
          fightOptions.appendChild(btn);
        });
      } else {
        fightArea.style.display = 'none';
        optionsArea.style.display = 'block';
        roomOptions(room).forEach((opt, index) => {
          const btn = document.createElement('button');
          btn.textContent = opt.text;
          btn.onclick = () => {
            applyAction(opt.action);
            if (opt.target) {
              goToRoom(opt.target);
            }
          };
          optionsContainer.appendChild(btn);
        });
      }
    }

    render();
  </script>
</body>
</html>
